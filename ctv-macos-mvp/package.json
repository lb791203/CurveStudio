{
  "name": "curvestudio-mvp",
  "version": "1.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "python3 -m http.server 4173",
    "dev:node": "node scripts/serve-static.mjs",
    "build:dist": "node scripts/build-dist.mjs",
    "test": "node scripts/run-tests.mjs",
    "audit:release": "node scripts/audit-release.mjs",
    "verify:windows-artifacts": "node scripts/verify-windows-artifacts.mjs",
    "validate:fixtures": "node scripts/validate-importers.mjs",
    "verify:release": "npm run audit:release && npm test && npm run validate:fixtures && npm run build:dist",
    "tauri:dev": "npx @tauri-apps/cli@latest dev",
    "tauri:build": "npx @tauri-apps/cli@latest build",
    "tauri:build:windows": "npx @tauri-apps/cli@latest build --config src-tauri/tauri.windows.conf.json"
  }
}
